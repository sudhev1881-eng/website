# StudentLink API Server Environment
# Copy to server/.env

PORT=4000
NODE_ENV=development

# PostgreSQL (used when database layer is implemented)
DATABASE_URL=postgresql://studentlink:studentlink@localhost:5432/studentlink

# File storage root (dev default: server/uploads — do not use /var/ without sudo)
STORAGE_PATH=./uploads

# Storage quota in GB for admin dashboard
STORAGE_QUOTA_GB=100

# Public URL written to NFC cards
SITE_URL=http://localhost:3000

# NFC reader — set to true when USB reader drivers are installed on the server
NFC_READER_ENABLED=false

# Seconds to wait for card placement during programming (milliseconds)
NFC_CARD_TIMEOUT_MS=30000

# CORS — allow the Next.js frontend origin
CORS_ORIGIN=http://localhost:3000

# JWT secret for auth tokens (change in production!)
JWT_SECRET=dev-secret-change-in-production

# Google OAuth — same Client ID as frontend (Web application)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
