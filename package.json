{
  "name": "studentlink",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "build:api": "npm run build --workspace=backend",
    "start": "npm run start --workspace=frontend",
    "start:api": "npm run start --workspace=backend",
    "lint": "npm run lint --workspace=frontend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:reset": "npm run db:reset --workspace=backend",
    "db:setup": "npm run db:setup --workspace=backend",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up -d --build"
  }
}
