# StudentLink API — Cloud Production Environment
# Copy to backend/.env and fill all required values.

NODE_ENV=production
PORT=4000

# Supabase PostgreSQL (Project Settings → Database → Connection string)
# Transaction mode — app runtime (port 6543, pgbouncer=true)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Session mode — migrations and seed only (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase (Project Settings → API)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studentlink

# Auth — min 32 characters; used for legacy JWT + claim tokens
JWT_SECRET=

# Public URLs (no trailing slash)
SITE_URL=https://yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Email via MailerSend (https://www.mailersend.com) — leave blank to disable alerts
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=StudentLink
# Where admin alerts go (new registrations, NFC requests). Defaults to MAILERSEND_FROM_EMAIL.
ADMIN_NOTIFY_EMAIL=admin@yourdomain.com

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
TRUST_PROXY=true
LOG_LEVEL=info

# NFC — cloud mode only (no USB reader on server)
NFC_CLOUD_MODE=true

# WebAuthn / Windows Hello (hostname only for RP ID; origin defaults to SITE_URL)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
