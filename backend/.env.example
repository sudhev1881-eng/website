# StudentLink API — Cloud Production Environment
# Copy to backend/.env and fill all required values.

NODE_ENV=production
PORT=4000

# Supabase PostgreSQL (Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase (Project Settings → API)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studentlink

# Auth — min 32 characters; used for legacy JWT + claim tokens
JWT_SECRET=

# Public URLs (no trailing slash)
SITE_URL=https://yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Email (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=StudentLink <noreply@yourdomain.com>

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
TRUST_PROXY=true
LOG_LEVEL=info

# NFC — cloud mode only (no USB reader on server)
NFC_CLOUD_MODE=true
