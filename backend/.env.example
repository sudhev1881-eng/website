# Supabase PostgreSQL — project xuzzglolfczqsiqdmywx (us-west-2)
# Transaction mode — app runtime (port 6543, pgbouncer=true)
DATABASE_URL="postgresql://postgres.xuzzglolfczqsiqdmywx:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode — migrations / Prisma (port 5432)
DIRECT_URL="postgresql://postgres.xuzzglolfczqsiqdmywx:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# Supabase (Project Settings → API)
SUPABASE_URL=https://xuzzglolfczqsiqdmywx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studentlink

# Auth — min 32 characters; used for legacy JWT + claim tokens
JWT_SECRET=

# Public URLs (no trailing slash)
SITE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

NODE_ENV=development
PORT=4000

# Email via MailerSend (https://www.mailersend.com) — leave blank to disable alerts
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=StudentLink
# Where admin alerts go (new registrations, NFC requests). Defaults to MAILERSEND_FROM_EMAIL.
ADMIN_NOTIFY_EMAIL=admin@yourdomain.com

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
TRUST_PROXY=true
LOG_LEVEL=info

# NFC — cloud mode only (no USB reader on server)
NFC_CLOUD_MODE=true

# Telegram Admin Assistant (optional — disabled unless TELEGRAM_ENABLED=true)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
# Shared secret for webhook path /api/telegram/webhook/:secret (and optional header)
TELEGRAM_WEBHOOK_SECRET=
# webhook (Render/production) or polling (local). Default: polling in development, webhook in production.
TELEGRAM_MODE=
TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook
# Bootstrap: comma-separated Telegram user IDs auto-linked as super_admin on first message
# (requires at least one users.role = 'admin' row). Prefer explicit SQL insert in production.
TELEGRAM_SUPER_ADMIN_IDS=
TELEGRAM_RATE_LIMIT_MAX=30
TELEGRAM_RATE_LIMIT_WINDOW_MS=60000
# Optional NL assist — core commands work without this
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Resume skill extraction (free, offline dictionary). Works without Redis.
RESUME_PROCESSING_ENABLED=true
# Optional Redis — when set, resume jobs use BullMQ with retries; otherwise in-process async.
REDIS_URL=
# Or host-based Redis (used only if REDIS_URL is empty):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
