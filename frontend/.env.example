# StudentLink Frontend — Vercel Environment Variables

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API (Oracle Cloud behind nginx)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Public site URL (profiles, NFC links)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Shown when a Google user has no pre-registered student profile
NEXT_PUBLIC_SUPPORT_EMAIL=support@studentlink.app
